<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Inventory ERP</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    :root {
      --sidebar-bg: #111827;
      --sidebar-hover: #2b2dfb;
      --bg-color: #f4f7fe;
      --text-main: #1f2a4d;
      --text-muted: #94a3b8;
      --card-radius: 20px;
    }
    body {
      background: var(--bg-color);
      font-family: 'Inter', sans-serif;
      color: var(--text-main);
    }
    .sidebar {
      width: 280px;
      position: fixed;
      inset: 0 auto 0 0;
      height: 100vh;
      background: linear-gradient(180deg, #111827, #0b1220);
      color: #fff;
      padding: 24px 18px;
      overflow-y: auto;
    }
    .main-content {
      margin-left: 280px;
      padding: 24px;
    }
    .brand-box {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 24px;
    }
    .brand-logo {
      width: 50px;
      height: 50px;
      border-radius: 14px;
      background: linear-gradient(135deg, #7c3aed, #2563eb);
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      font-weight: 800;
      font-size: 22px;
    }
    .nav-section {
      color: #8c93b8;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.08em;
      margin: 18px 0 10px;
      text-transform: uppercase;
    }
    .sidebar .nav-link {
      color: #e6e9f5;
      border-radius: 14px;
      padding: 11px 14px;
      margin-bottom: 6px;
      display: flex;
      align-items: center;
      gap: 10px;
      transition: 0.2s;
    }
    .sidebar .nav-link:hover,
    .sidebar .nav-link.active {
      background: var(--sidebar-hover);
      color: #fff;
    }
    .logout-link { color: #ff8a8a !important; }
    .topbar {
      background: #fff;
      border-radius: 20px;
      padding: 16px 18px;
      box-shadow: 0 10px 30px rgba(15,23,42,0.06);
      margin-bottom: 24px;
    }
    .card-soft {
      background: #fff;
      border: none;
      border-radius: var(--card-radius);
      box-shadow: 0 10px 30px rgba(15,23,42,0.06);
    }
    .metric-card {
      color: #fff;
      border-radius: var(--card-radius);
      border: none;
      min-height: 130px;
    }
    .metric-icon {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(255,255,255,0.18);
      margin-bottom: 12px;
    }
    .bg-purple { background: linear-gradient(135deg, #6366F1, #7C3AED); }
    .bg-green { background: linear-gradient(135deg, #00B87C, #0FBF84); }
    .bg-orange { background: linear-gradient(135deg, #FF9C00, #FFB84D); }
    .bg-blue { background: linear-gradient(135deg, #0075FF, #00A3FF); }
    .bg-pink { background: linear-gradient(135deg, #FF4C61, #FF7A8B); }
    .form-control, .form-select {
      border-radius: 12px;
      min-height: 46px;
      border: 1px solid #E2E8F0;
    }
    .form-control:focus, .form-select:focus {
      border-color: #6366F1;
      box-shadow: 0 0 0 0.2rem rgba(99,102,241,0.10);
    }
    .btn-rounded { border-radius: 12px; }
    .badge-soft { border-radius: 999px; padding: 8px 12px; }
    .status-approved { background: #E7F9F0; color: #00B87C; }
    .status-declined { background: #FDECEC; color: #FF4C61; }
    .status-pending { background: #FFF4DB; color: #FF9C00; }
    .table thead th {
      color: var(--text-muted);
      font-size: 12px;
      text-transform: uppercase;
      border-bottom: 1px solid #EEF2F7;
    }
    .table td, .table th { vertical-align: middle; }
    .avatar-sm { width: 38px; height: 38px; border-radius: 50%; object-fit: cover; }
    .navbar-search { max-width: 320px; }
    @media (max-width: 992px) {
      .sidebar { transform: translateX(-100%); transition: .25s ease; }
      .sidebar.show { transform: translateX(0); }
      .main-content { margin-left: 0; }
    }
  </style>
</head>
<body>
  <aside class="sidebar">
    <div class="brand-box">
      <div class="brand-logo"><i class="fa-solid fa-boxes-stacked"></i></div>
      <div>
        <div class="fw-bold">Inventory ERP</div>
        <small class="text-muted" style="color:#A3AED0 !important;">Management System</small>
      </div>
    </div>

    <div class="nav-section">Dashboard</div>
    <a href="/app?page=dashboard" class="nav-link <%= page==='dashboard' ? 'active' : '' %>"><i class="fa-solid fa-gauge-high"></i> Dashboard</a>

    <div class="nav-section">Master Data</div>
    <a href="/app?page=products" class="nav-link <%= page==='products' ? 'active' : '' %>"><i class="fa-solid fa-box"></i> Products</a>
    <a href="/app?page=categories" class="nav-link <%= page==='categories' ? 'active' : '' %>"><i class="fa-solid fa-tags"></i> Categories</a>
    <a href="/app?page=suppliers" class="nav-link <%= page==='suppliers' ? 'active' : '' %>"><i class="fa-solid fa-truck-field"></i> Suppliers</a>
    <a href="/app?page=warehouses" class="nav-link <%= page==='warehouses' ? 'active' : '' %>"><i class="fa-solid fa-warehouse"></i> Warehouses</a>

    <div class="nav-section">Operations</div>
    <a href="/app?page=stock" class="nav-link <%= page==='stock' ? 'active' : '' %>"><i class="fa-solid fa-right-left"></i> Stock Movements</a>
    <a href="/app?page=purchases" class="nav-link <%= page==='purchases' ? 'active' : '' %>"><i class="fa-solid fa-cart-shopping"></i> Purchases</a>
    <a href="/app?page=sales" class="nav-link <%= page==='sales' ? 'active' : '' %>"><i class="fa-solid fa-receipt"></i> Sales</a>

    <div class="nav-section">System</div>
    <a href="/app?page=notifications" class="nav-link <%= page==='notifications' ? 'active' : '' %>"><i class="fa-solid fa-bell"></i> Notifications</a>
    <a href="/app?page=users" class="nav-link <%= page==='users' ? 'active' : '' %>"><i class="fa-solid fa-users"></i> Users</a>
    <a href="/app?page=settings" class="nav-link <%= page==='settings' ? 'active' : '' %>"><i class="fa-solid fa-gear"></i> Settings</a>
    <a href="/app?page=audit" class="nav-link <%= page==='audit' ? 'active' : '' %>"><i class="fa-solid fa-shield-halved"></i> Audit Logs</a>

    <div class="mt-4">
      <a href="/logout" class="btn btn-outline-light w-100 btn-rounded"><i class="fa-solid fa-right-from-bracket me-2"></i>Logout</a>
    </div>
  </aside>

  <main class="main-content">
    <div class="topbar d-flex align-items-center justify-content-between flex-wrap gap-3">
      <div>
        <h4 class="mb-1"><%= pageTitle || 'Dashboard' %></h4>
        <div class="text-muted">Welcome, <strong><%= user.full_name %></strong></div>
      </div>
      <div class="d-flex gap-2 flex-wrap">
        <button class="btn btn-outline-primary btn-rounded" data-bs-toggle="modal" data-bs-target="#quickCreateModal">
          <i class="fa-solid fa-plus me-2"></i>Quick Create
        </button>
        <button class="btn btn-primary btn-rounded" data-bs-toggle="modal" data-bs-target="#authModal">
          <i class="fa-solid fa-key me-2"></i>Change Password
        </button>
      </div>
    </div>

    <% if (message) { %>
      <div class="alert alert-success alert-dismissible fade show card-soft" role="alert">
        <%= message %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% } %>

    <% if (page === 'dashboard') { %>
      <div class="row g-4 mb-4">
        <div class="col-md-6 col-xl-2-4">
          <div class="card metric-card bg-purple p-4">
            <div class="metric-icon"><i class="fa-solid fa-box"></i></div>
            <div class="fs-5 fw-semibold">Products</div>
            <div class="display-6 fw-bold"><%= productsCount || 0 %></div>
          </div>
        </div>
        <div class="col-md-6 col-xl-2-4">
          <div class="card metric-card bg-green p-4">
            <div class="metric-icon"><i class="fa-solid fa-tags"></i></div>
            <div class="fs-5 fw-semibold">Categories</div>
            <div class="display-6 fw-bold"><%= categoriesCount || 0 %></div>
          </div>
        </div>
        <div class="col-md-6 col-xl-2-4">
          <div class="card metric-card bg-orange p-4">
            <div class="metric-icon"><i class="fa-solid fa-truck-field"></i></div>
            <div class="fs-5 fw-semibold">Suppliers</div>
            <div class="display-6 fw-bold"><%= suppliersCount || 0 %></div>
          </div>
        </div>
        <div class="col-md-6 col-xl-2-4">
          <div class="card metric-card bg-blue p-4">
            <div class="metric-icon"><i class="fa-solid fa-warehouse"></i></div>
            <div class="fs-5 fw-semibold">Warehouses</div>
            <div class="display-6 fw-bold"><%= warehousesCount || 0 %></div>
          </div>
        </div>
        <div class="col-md-6 col-xl-2-4">
          <div class="card metric-card bg-pink p-4">
            <div class="metric-icon"><i class="fa-solid fa-triangle-exclamation"></i></div>
            <div class="fs-5 fw-semibold">Low Stock</div>
            <div class="display-6 fw-bold"><%= lowStockCount || 0 %></div>
          </div>
        </div>
      </div>

      <div class="row g-4">
        <div class="col-lg-8">
          <div class="card card-soft p-4">
            <h5 class="mb-3">Sales Trend</h5>
            <div style="position:relative; height:320px;">
              <canvas id="trendChart"></canvas>
            </div>
          </div>
        </div>
        <div class="col-lg-4">
          <div class="card card-soft p-4 h-100">
            <h5 class="mb-3">Recent Notifications</h5>
            <div class="vstack gap-3">
              <% (notifications || []).forEach(function(n){ %>
                <div class="p-3 rounded-4 border">
                  <div class="fw-semibold"><%= n.title %></div>
                  <div class="small text-muted"><%= n.message %></div>
                </div>
              <% }) %>
              <% if (!notifications || !notifications.length) { %>
                <div class="text-muted">No notifications found.</div>
              <% } %>
            </div>
          </div>
        </div>
      </div>

      <script>
        const trendCtx = document.getElementById('trendChart');
        if (trendCtx) {
          new Chart(trendCtx, {
            type: 'line',
            data: {
              labels: <%- JSON.stringify(chartLabels || []) %>,
              datasets: [{
                label: 'Sales',
                data: <%- JSON.stringify(chartData || []) %>,
                borderColor: '#2563eb',
                backgroundColor: 'rgba(37,99,235,.12)',
                tension: 0.35,
                fill: true
              }]
            },
            options: { responsive: true, maintainAspectRatio: false }
          });
        }
      </script>
    <% } else if (page === 'categories') { %>
      <div class="row g-4">
        <div class="col-lg-4">
          <div class="card card-soft p-4">
            <h5 class="mb-3">Add Category</h5>
            <form method="POST" action="/app">
              <input type="hidden" name="action" value="add_category">
              <div class="mb-3">
                <label class="form-label">Name</label>
                <input type="text" name="name" class="form-control" required>
              </div>
              <div class="mb-3">
                <label class="form-label">Description</label>
                <textarea name="description" class="form-control" rows="4"></textarea>
              </div>
              <button class="btn btn-primary btn-rounded w-100">Save</button>
            </form>
          </div>
        </div>
        <div class="col-lg-8">
          <div class="card card-soft p-4">
            <h5 class="mb-3">Categories</h5>
            <div class="table-responsive">
              <table class="table align-middle">
                <thead><tr><th>Name</th><th>Description</th><th>Action</th></tr></thead>
                <tbody>
                  <% (categories || []).forEach(function(c){ %>
                    <tr>
                      <td><%= c.name %></td>
                      <td><%= c.description %></td>
                      <td>
                        <a href="/app?page=categories&delete=1&table=categories&id=<%= c._id %>" class="btn btn-sm btn-danger btn-rounded">
                          <i class="fa-solid fa-trash"></i>
                        </a>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    <% } else if (page === 'suppliers') { %>
      <div class="row g-4">
        <div class="col-lg-4">
          <div class="card card-soft p-4">
            <h5 class="mb-3">Add Supplier</h5>
            <form method="POST" action="/app">
              <input type="hidden" name="action" value="add_supplier">
              <div class="mb-3">
                <label class="form-label">Company Name</label>
                <input type="text" name="companyName" class="form-control" required>
              </div>
              <div class="mb-3">
                <label class="form-label">Contact Person</label>
                <input type="text" name="contactPerson" class="form-control">
              </div>
              <div class="mb-3">
                <label class="form-label">Email</label>
                <input type="email" name="email" class="form-control">
              </div>
              <div class="mb-3">
                <label class="form-label">Phone</label>
                <input type="text" name="phone" class="form-control">
              </div>
              <div class="mb-3">
                <label class="form-label">Address</label>
                <textarea name="address" class="form-control" rows="3"></textarea>
              </div>
              <button class="btn btn-primary btn-rounded w-100">Save</button>
            </form>
          </div>
        </div>
        <div class="col-lg-8">
          <div class="card card-soft p-4">
            <h5 class="mb-3">Suppliers</h5>
            <div class="table-responsive">
              <table class="table align-middle">
                <thead><tr><th>Code</th><th>Company</th><th>Contact</th><th>Email</th><th>Action</th></tr></thead>
                <tbody>
                  <% (suppliers || []).forEach(function(s){ %>
                    <tr>
                      <td><%= s.supplierCode %></td>
                      <td><%= s.companyName %></td>
                      <td><%= s.contactPerson %></td>
                      <td><%= s.email %></td>
                      <td>
                        <a href="/app?page=suppliers&delete=1&table=suppliers&id=<%= s._id %>" class="btn btn-sm btn-danger btn-rounded">
                          <i class="fa-solid fa-trash"></i>
                        </a>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    <% } else if (page === 'warehouses') { %>
      <div class="row g-4">
        <div class="col-lg-4">
          <div class="card card-soft p-4">
            <h5 class="mb-3">Add Warehouse</h5>
            <form method="POST" action="/app">
              <input type="hidden" name="action" value="add_warehouse">
              <div class="mb-3">
                <label class="form-label">Name</label>
                <input type="text" name="name" class="form-control" required>
              </div>
              <div class="mb-3">
                <label class="form-label">Location</label>
                <input type="text" name="location" class="form-control">
              </div>
              <div class="mb-3">
                <label class="form-label">Manager Name</label>
                <input type="text" name="managerName" class="form-control">
              </div>
              <button class="btn btn-primary btn-rounded w-100">Save</button>
            </form>
          </div>
        </div>
        <div class="col-lg-8">
          <div class="card card-soft p-4">
            <h5 class="mb-3">Warehouses</h5>
            <div class="table-responsive">
              <table class="table align-middle">
                <thead><tr><th>Code</th><th>Name</th><th>Location</th><th>Manager</th><th>Action</th></tr></thead>
                <tbody>
                  <% (warehouses || []).forEach(function(w){ %>
                    <tr>
                      <td><%= w.code %></td>
                      <td><%= w.name %></td>
                      <td><%= w.location %></td>
                      <td><%= w.managerName %></td>
                      <td>
                        <a href="/app?page=warehouses&delete=1&table=warehouses&id=<%= w._id %>" class="btn btn-sm btn-danger btn-rounded">
                          <i class="fa-solid fa-trash"></i>
                        </a>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    <% } else if (page === 'products') { %>
      <div class="row g-4">
        <div class="col-lg-4">
          <div class="card card-soft p-4">
            <h5 class="mb-3">Add Product</h5>
            <form method="POST" action="/app">
              <input type="hidden" name="action" value="add_product">
              <div class="mb-3">
                <label class="form-label">SKU</label>
                <input type="text" name="sku" class="form-control">
              </div>
              <div class="mb-3">
                <label class="form-label">Name</label>
                <input type="text" name="name" class="form-control" required>
              </div>
              <div class="mb-3">
                <label class="form-label">Category</label>
                <select name="categoryId" class="form-select">
                  <option value="">Select</option>
                  <% (categories || []).forEach(function(c){ %><option value="<%= c._id %>"><%= c.name %></option><% }) %>
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label">Supplier</label>
                <select name="supplierId" class="form-select">
                  <option value="">Select</option>
                  <% (suppliers || []).forEach(function(s){ %><option value="<%= s._id %>"><%= s.companyName %></option><% }) %>
                </select>
              </div>
              <div class="row g-2">
                <div class="col-6 mb-3">
                  <label class="form-label">Cost Price</label>
                  <input type="number" name="costPrice" class="form-control" step="0.01" value="0">
                </div>
                <div class="col-6 mb-3">
                  <label class="form-label">Selling Price</label>
                  <input type="number" name="sellingPrice" class="form-control" step="0.01" value="0">
                </div>
              </div>
              <div class="row g-2">
                <div class="col-6 mb-3">
                  <label class="form-label">Stock Qty</label>
                  <input type="number" name="stockQty" class="form-control" value="0">
                </div>
                <div class="col-6 mb-3">
                  <label class="form-label">Reorder Level</label>
                  <input type="number" name="reorderLevel" class="form-control" value="0">
                </div>
              </div>
              <div class="mb-3">
                <label class="form-label">Unit</label>
                <input type="text" name="unit" class="form-control" value="pcs">
              </div>
              <div class="mb-3">
                <label class="form-label">Description</label>
                <textarea name="description" class="form-control" rows="3"></textarea>
              </div>
              <button class="btn btn-primary btn-rounded w-100">Save</button>
            </form>
          </div>
        </div>
        <div class="col-lg-8">
          <div class="card card-soft p-4">
            <h5 class="mb-3">Products</h5>
            <div class="table-responsive">
              <table class="table align-middle">
                <thead><tr><th>SKU</th><th>Name</th><th>Category</th><th>Supplier</th><th>Stock</th><th>Action</th></tr></thead>
                <tbody>
                  <% (products || []).forEach(function(p){ %>
                    <tr>
                      <td><%= p.sku %></td>
                      <td><%= p.name %></td>
                      <td><%= p.categoryId ? p.categoryId.name : '' %></td>
                      <td><%= p.supplierId ? p.supplierId.companyName : '' %></td>
                      <td><%= p.stockQty %></td>
                      <td>
                        <a href="/app?page=products&delete=1&table=products&id=<%= p._id %>" class="btn btn-sm btn-danger btn-rounded">
                          <i class="fa-solid fa-trash"></i>
                        </a>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    <% } else if (page === 'stock') { %>
      <div class="row g-4">
        <div class="col-lg-4">
          <div class="card card-soft p-4">
            <h5 class="mb-3">Stock Movement</h5>
            <form method="POST" action="/app">
              <input type="hidden" name="action" value="add_stock">
              <div class="mb-3">
                <label class="form-label">Product</label>
                <select name="productId" class="form-select" required>
                  <option value="">Select</option>
                  <% (products || []).forEach(function(p){ %><option value="<%= p._id %>"><%= p.name %></option><% }) %>
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label">Warehouse</label>
                <select name="warehouseId" class="form-select">
                  <option value="">Select</option>
                  <% (warehouses || []).forEach(function(w){ %><option value="<%= w._id %>"><%= w.name %></option><% }) %>
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label">Movement Type</label>
                <select name="movementType" class="form-select" required>
                  <option value="IN">IN</option>
                  <option value="OUT">OUT</option>
                  <option value="ADJUST">ADJUST</option>
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label">Quantity</label>
                <input type="number" name="quantity" class="form-control" required>
              </div>
              <div class="mb-3">
                <label class="form-label">Notes</label>
                <textarea name="notes" class="form-control" rows="3"></textarea>
              </div>
              <button class="btn btn-primary btn-rounded w-100">Save</button>
            </form>
          </div>
        </div>
        <div class="col-lg-8">
          <div class="card card-soft p-4">
            <h5 class="mb-3">Movements</h5>
            <div class="table-responsive">
              <table class="table align-middle">
                <thead><tr><th>Code</th><th>Product</th><th>Warehouse</th><th>Type</th><th>Qty</th><th>Date</th></tr></thead>
                <tbody>
                  <% (movements || []).forEach(function(m){ %>
                    <tr>
                      <td><%= m.movementCode %></td>
                      <td><%= m.productId ? m.productId.name : '' %></td>
                      <td><%= m.warehouseId ? m.warehouseId.name : '' %></td>
                      <td><%= m.movementType %></td>
                      <td><%= m.quantity %></td>
                      <td><%= m.createdAt ? new Date(m.createdAt).toLocaleDateString() : '' %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    <% } else if (page === 'purchases') { %>
      <div class="row g-4">
        <div class="col-lg-4">
          <div class="card card-soft p-4">
            <h5 class="mb-3">Add Purchase</h5>
            <form method="POST" action="/app">
              <input type="hidden" name="action" value="add_purchase">
              <div class="mb-3">
                <label class="form-label">Supplier</label>
                <select name="supplierId" class="form-select" required>
                  <option value="">Select</option>
                  <% (suppliers || []).forEach(function(s){ %><option value="<%= s._id %>"><%= s.companyName %></option><% }) %>
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label">Purchase Date</label>
                <input type="date" name="purchaseDate" class="form-control">
              </div>
              <div class="mb-3">
                <label class="form-label">Total Amount</label>
                <input type="number" name="totalAmount" class="form-control" value="0">
              </div>
              <div class="mb-3">
                <label class="form-label">Paid Amount</label>
                <input type="number" name="paidAmount" class="form-control" value="0">
              </div>
              <div class="mb-3">
                <label class="form-label">Payment Status</label>
                <select name="paymentStatus" class="form-select">
                  <option>Pending</option>
                  <option>Partial</option>
                  <option>Paid</option>
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label">Notes</label>
                <textarea name="notes" class="form-control" rows="3"></textarea>
              </div>
              <button class="btn btn-primary btn-rounded w-100">Save</button>
            </form>
          </div>
        </div>
        <div class="col-lg-8">
          <div class="card card-soft p-4">
            <h5 class="mb-3">Purchases</h5>
            <div class="table-responsive">
              <table class="table align-middle">
                <thead><tr><th>Code</th><th>Supplier</th><th>Total</th><th>Paid</th><th>Balance</th><th>Status</th></tr></thead>
                <tbody>
                  <% (purchases || []).forEach(function(p){ %>
                    <tr>
                      <td><%= p.purchaseCode %></td>
                      <td><%= p.supplierId ? p.supplierId.companyName : '' %></td>
                      <td><%= p.totalAmount %></td>
                      <td><%= p.paidAmount %></td>
                      <td><%= p.balanceAmount %></td>
                      <td><%= p.paymentStatus %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    <% } else if (page === 'sales') { %>
      <div class="row g-4">
        <div class="col-lg-4">
          <div class="card card-soft p-4">
            <h5 class="mb-3">Add Sale</h5>
            <form method="POST" action="/app">
              <input type="hidden" name="action" value="add_sale">
              <div class="mb-3">
                <label class="form-label">Customer Name</label>
                <input type="text" name="customerName" class="form-control" required>
              </div>
              <div class="mb-3">
                <label class="form-label">Customer Email</label>
                <input type="email" name="customerEmail" class="form-control">
              </div>
              <div class="mb-3">
                <label class="form-label">Sale Date</label>
                <input type="date" name="saleDate" class="form-control">
              </div>
              <div class="mb-3">
                <label class="form-label">Total Amount</label>
                <input type="number" name="totalAmount" class="form-control" value="0">
              </div>
              <div class="mb-3">
                <label class="form-label">Paid Amount</label>
                <input type="number" name="paidAmount" class="form-control" value="0">
              </div>
              <div class="mb-3">
                <label class="form-label">Payment Status</label>
                <select name="paymentStatus" class="form-select">
                  <option>Pending</option>
                  <option>Partial</option>
                  <option>Paid</option>
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label">Notes</label>
                <textarea name="notes" class="form-control" rows="3"></textarea>
              </div>
              <button class="btn btn-primary btn-rounded w-100">Save</button>
            </form>
          </div>
        </div>
        <div class="col-lg-8">
          <div class="card card-soft p-4">
            <h5 class="mb-3">Sales</h5>
            <div class="table-responsive">
              <table class="table align-middle">
                <thead><tr><th>Code</th><th>Customer</th><th>Total</th><th>Paid</th><th>Balance</th><th>Status</th></tr></thead>
                <tbody>
                  <% (sales || []).forEach(function(s){ %>
                    <tr>
                      <td><%= s.saleCode %></td>
                      <td><%= s.customerName %></td>
                      <td><%= s.totalAmount %></td>
                      <td><%= s.paidAmount %></td>
                      <td><%= s.balanceAmount %></td>
                      <td><%= s.paymentStatus %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    <% } else if (page === 'notifications') { %>
      <div class="card card-soft p-4">
        <h5 class="mb-3">Notifications</h5>
        <form method="POST" action="/app" class="mb-4">
          <input type="hidden" name="action" value="send_notification">
          <div class="row g-3">
            <div class="col-md-4">
              <label class="form-label">Title</label>
              <input type="text" name="title" class="form-control" required>
            </div>
            <div class="col-md-4">
              <label class="form-label">Type</label>
              <input type="text" name="type" class="form-control" placeholder="Info">
            </div>
            <div class="col-md-4">
              <label class="form-label">Message</label>
              <input type="text" name="message" class="form-control" required>
            </div>
          </div>
          <button class="btn btn-primary btn-rounded mt-3">Send</button>
        </form>

        <div class="table-responsive">
          <table class="table align-middle">
            <thead><tr><th>Title</th><th>Message</th><th>Type</th><th>Date</th><th>Action</th></tr></thead>
            <tbody>
              <% (notifications || []).forEach(function(n){ %>
                <tr>
                  <td><%= n.title %></td>
                  <td><%= n.message %></td>
                  <td><%= n.type %></td>
                  <td><%= n.createdAt ? new Date(n.createdAt).toLocaleString() : '' %></td>
                  <td>
                    <a href="/app?page=notifications&delete=1&table=notifications&id=<%= n._id %>" class="btn btn-sm btn-danger btn-rounded">
                      <i class="fa-solid fa-trash"></i>
                    </a>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    <% } else if (page === 'users') { %>
      <div class="row g-4">
        <div class="col-lg-4">
          <div class="card card-soft p-4">
            <h5 class="mb-3">Add User</h5>
            <form method="POST" action="/app">
              <input type="hidden" name="action" value="add_user">
              <div class="mb-3">
                <label class="form-label">Full Name</label>
                <input type="text" name="full_name" class="form-control" required>
              </div>
              <div class="mb-3">
                <label class="form-label">Email</label>
                <input type="email" name="email" class="form-control" required>
              </div>
              <div class="mb-3">
                <label class="form-label">Password</label>
                <input type="text" name="password" class="form-control" placeholder="123456">
              </div>
              <div class="mb-3">
                <label class="form-label">Role</label>
                <select name="role" class="form-select">
                  <option value="viewer">viewer</option>
                  <option value="admin">admin</option>
                  <option value="manager">manager</option>
                  <option value="staff">staff</option>
                  <option value="accountant">accountant</option>
                </select>
              </div>
              <button class="btn btn-primary btn-rounded w-100">Save</button>
            </form>
          </div>
        </div>
        <div class="col-lg-8">
          <div class="card card-soft p-4">
            <h5 class="mb-3">Users</h5>
            <div class="table-responsive">
              <table class="table align-middle">
                <thead><tr><th>Name</th><th>Email</th><th>Role</th><th>Action</th></tr></thead>
                <tbody>
                  <% (users || []).forEach(function(u){ %>
                    <tr>
                      <td><%= u.full_name %></td>
                      <td><%= u.email %></td>
                      <td><%= u.role %></td>
                      <td>
                        <a href="/app?page=users&delete=1&table=users&id=<%= u._id %>" class="btn btn-sm btn-danger btn-rounded">
                          <i class="fa-solid fa-trash"></i>
                        </a>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    <% } else if (page === 'audit') { %>
      <div class="card card-soft p-4">
        <h5 class="mb-3">Audit Logs</h5>
        <div class="table-responsive">
          <table class="table align-middle">
            <thead><tr><th>Action</th><th>Entity</th><th>Summary</th><th>Date</th></tr></thead>
            <tbody>
              <% (auditlogs || []).forEach(function(a){ %>
                <tr>
                  <td><%= a.action %></td>
                  <td><%= a.entityName %></td>
                  <td><%= a.summary %></td>
                  <td><%= a.createdAt ? new Date(a.createdAt).toLocaleString() : '' %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    <% } else if (page === 'settings') { %>
      <div class="card card-soft p-4">
        <h5 class="mb-3">Settings</h5>
        <p class="text-muted">System settings storage is ready.</p>
        <div class="table-responsive">
          <table class="table align-middle">
            <thead><tr><th>Key</th><th>Value</th><th>Label</th></tr></thead>
            <tbody>
              <% (settings || []).forEach(function(s){ %>
                <tr>
                  <td><%= s.key %></td>
                  <td><%= typeof s.value === 'object' ? JSON.stringify(s.value) : s.value %></td>
                  <td><%= s.label %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    <% } else { %>
      <div class="alert alert-warning card-soft">Page not found.</div>
    <% } %>
  </main>

  <div class="modal fade" id="authModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content card-soft">
        <div class="modal-header">
          <h5 class="modal-title">Change Password</h5>
          <button class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <form>
            <div class="mb-3">
              <label class="form-label">Current Password</label>
              <input type="password" class="form-control" disabled>
            </div>
            <div class="mb-3">
              <label class="form-label">New Password</label>
              <input type="password" class="form-control" disabled>
            </div>
            <div class="alert alert-info mb-0">Password change architecture is ready for extension.</div>
          </form>
        </div>
      </div>
    </div>
  </div>

  <div class="modal fade" id="quickCreateModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content card-soft">
        <div class="modal-header">
          <h5 class="modal-title">Quick Create</h5>
          <button class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="alert alert-secondary mb-0">Use the module forms to add records quickly.</div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
