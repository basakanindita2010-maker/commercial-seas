<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Student Management System - Login</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body {
      margin: 0;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #F4F7FE;
      font-family: 'Inter', sans-serif;
    }
    .login-card {
      width: 100%;
      max-width: 420px;
      background: #fff;
      padding: 50px 40px;
      border-radius: 24px;
      box-shadow: 0 18px 50px rgba(15, 23, 42, 0.12);
    }
    .logo-box {
      width: 50px;
      height: 50px;
      border-radius: 12px;
      margin: 0 auto 16px auto;
      background: linear-gradient(135deg, #FF9C00, #FFC048);
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      font-weight: 700;
      font-size: 24px;
    }
    .form-control {
      background: #F8FAFC;
      border: 1px solid #E2E8F0;
      border-radius: 12px;
      padding: 12px 14px;
    }
    .form-control:focus {
      border-color: #6366F1;
      box-shadow: 0 0 0 0.2rem rgba(99,102,241,0.15);
    }
    .btn-signin {
      background: #6366F1;
      color: #fff;
      border: none;
      border-radius: 12px;
      padding: 12px 16px;
      font-weight: 600;
    }
    .btn-signin:hover {
      background: #4F46E5;
      color: #fff;
    }
  </style>
</head>
<body>
  <div class="login-card">
    <div class="logo-box">S</div>
    <h3 class="text-center fw-bold mb-1">Welcome Back</h3>
    <p class="text-center text-muted mb-4">Student Management System</p>

    <% if (error) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <form method="POST" action="/login">
      <div class="mb-3">
        <label class="form-label">Email</label>
        <input type="text" name="email" class="form-control" placeholder="Enter email" required>
      </div>
      <div class="mb-4">
        <label class="form-label">Password</label>
        <input type="password" name="password" class="form-control" placeholder="Enter password" required>
      </div>
      <button type="submit" class="btn btn-signin w-100">Sign In</button>
    </form>
  </div>
</body>
</html>