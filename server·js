    { key: 'session_timeout_minutes', value: 480, label: 'Session Timeout', description: 'Session timeout in minutes' }
  ];

  for (const item of defaults) {
    const exists = await Setting.findOne({ key: item.key }).lean();
    if (!exists) {
      await Setting.create({ ...item, status: 'Active', createdBy: null });
    }
  }

  const modules = [
    ['dashboard', 'Dashboard', 'fa-gauge', '/app?page=dashboard'],
    ['users', 'Users', 'fa-users', '/app?page=users'],
    ['clients', 'Clients', 'fa-building', '/app?page=clients'],
