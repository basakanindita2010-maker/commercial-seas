app.post('/forgot-password', async (req, res) => {
  try {
    const email = sanitizeInput(req.body.email).toLowerCase();
    const user = await User.findOne({ email });
    if (!user) {
      req.session.flash = { type: 'warning', message: 'If the email exists, a reset process has been initiated.' };
      return res.redirect('/login');
    }

    const token = crypto.randomBytes(24).toString('hex');
    user.resetTokenHash = hashPassword(token);
    user.resetTokenExpiresAt = new Date(Date.now() + 1000 * 60 * 30);
    await user.save();

    await logAudit({ user: req.session.user || null, action: 'Settings', entityName: 'User', entityId: user._id, summary: `Password reset requested for ${user.email}` }, req);

    req.session.flash = { type: 'success', message: `Password reset token generated. Token: ${token}` };
    return res.redirect('/login');
  } catch (error) {
    console.error(error);
    req.session.flash = { type: 'danger', message: 'Unable to process forgot password request.' };
    return res.redirect('/login');
  }
});

app.get('/app', ensureAuthenticated, async (req, res) => {
  try {
    const page = String(req.query.page || 'dashboard').toLowerCase();
    const cfg = pageConfigs[page] || pageConfigs.dashboard;
    const modelInfo = cfg.modelKey ? MODELS[cfg.modelKey] : null;
    const model = modelInfo ? modelInfo.model : null;
    const search = sanitizeInput(req.query.search || '');
    const sort = sanitizeInput(req.query.sort || 'createdAt');
    const dir = String(req.query.dir || 'desc').toLowerCase() === 'asc' ? 1 : -1;
    const status = sanitizeInput(req.query.status || '');
    const currentPage = Math.max(parseInt(req.query.p || '1', 10) || 1, 1);
    const perPage = Math.min(Math.max(parseInt(req.query.limit || '10', 10) || 10, 5), 100);

    const canCreate = hasPermission(req.session.user, 'create');
    const canRead = hasPermission(req.session.user, 'read');
    const canUpdate = hasPermission(req.session.user, 'update');
    const canDelete = hasPermission(req.session.user, 'delete');
    const canExport = hasPermission(req.session.user, 'export');
    const canPrint = hasPermission(req.session.user, 'print');

    if (!canRead) {
      return res.status(403).render('app', {
        appName: APP_NAME,
        page: 'dashboard',
        cfg: pageConfigs.dashboard,
        rows: [],
        record: null,
        meta: {},
        stats: {},
        charts: {},
        relations: {},
        error: 'You do not have permission to view this content.',
        flash: null,
        currentUser: req.session.user,
        canCreate, canRead, canUpdate, canDelete, canExport, canPrint
      });
    }

    if (page === 'dashboard') {
      const [usersCount, clientsCount, projectsCount, tasksCount, invoicesCount, paymentsCount, notificationsCount, auditCount] = await Promise.all([
        User.countDocuments({ status: 'Active' }),
        Client.countDocuments({ status: 'Active' }),
        Project.countDocuments({ status: 'Active' }),
        Task.countDocuments({ status: { $ne: 'Done' } }),
        Invoice.countDocuments({ status: 'Active' }),
        Payment.countDocuments({ status: 'Active' }),
        Notification.countDocuments({ status: 'Active' }),
        AuditLog.countDocuments({})
      ]);

      const recentActivities = await AuditLog.find({})
        .sort({ createdAt: -1 })
        .limit(8)
        .lean();

      const latestClients = await Client.find({})
        .sort({ createdAt: -1 })
        .limit(6)
        .lean();

      const monthlyInvoiceAgg = await Invoice.aggregate([
        { $group: { _id: { $month: '$createdAt' }, total: { $sum: '$totalAmount' } } },
        { $sort: { _id: 1 } }
      ]);

      const chartLabels = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
      const invoiceSeries = Array(12).fill(0);
      monthlyInvoiceAgg.forEach(x => { invoiceSeries[x._id - 1] = x.total; });

      return res.render('app', {
        appName: APP_NAME,
        page: 'dashboard',
        cfg: pageConfigs.dashboard,
        rows: [],
        record: null,
        meta: {},
        stats: {
          usersCount,
          clientsCount,
          projectsCount,
          tasksCount,
          invoicesCount,
          paymentsCount,
          notificationsCount,
          auditCount
        },
        charts: {
          labels: chartLabels,
          invoiceSeries
        },
        relations: {},
        recentActivities,
        latestClients,
        error: null,
        flash: req.session.flash || null,
        currentUser: req.session.user,
        canCreate, canRead, canUpdate, canDelete, canExport, canPrint,
        search, sort, dir, status,
        pageTitle: 'Dashboard'
      });
    }

    if (!model) {
      return res.status(404).render('app', {
        appName: APP_NAME,
        page,
        cfg: pageConfigs.dashboard,
        rows: [],
        record: null,
        meta: {},
        stats: {},
        charts: {},
        relations: {},
        error: 'Module not found.',
        flash: null,
        currentUser: req.session.user,
        canCreate, canRead, canUpdate, canDelete, canExport, canPrint
      });
    }

    const filter = {};
    if (search) {
      filter.$or = Object.keys(model.schema.paths)
        .filter(k => !['_id', '__v', 'createdAt', 'updatedAt', 'createdBy'].includes(k))
        .slice(0, 5)
        .map(k => ({ [k]: { $regex: search, $options: 'i' } }));
    }
    if (status) filter.status = status;

    const total = await model.countDocuments(filter);
    const totalPages = Math.max(Math.ceil(total / perPage), 1);
    const skip = (currentPage - 1) * perPage;

    const rows = await model.find(filter)
      .sort({ [sort]: dir })
      .skip(skip)
      .limit(perPage)
      .populate('createdBy', 'fullName email role')
      .populate('clientId', 'companyName clientCode')
      .populate('ownerId', 'fullName email')
      .populate('projectId', 'title projectCode')
      .populate('assignedTo', 'fullName email')
      .populate('invoiceId', 'invoiceNumber totalAmount')
      .populate('recipientId', 'fullName email')
      .populate('relatedEntity', 'title')
      .lean();

    const relations = {
      users: await User.find({ status: 'Active' }).sort({ fullName: 1 }).lean(),
      clients: await Client.find({ status: 'Active' }).sort({ companyName: 1 }).lean(),
      projects: await Project.find({ status: 'Active' }).sort({ title: 1 }).lean(),
      invoices: await Invoice.find({ status: 'Active' }).sort({ invoiceNumber: 1 }).lean(),
      tasks: await Task.find({ status: { $ne: 'Done' } }).sort({ title: 1 }).lean()
    };

    const editId = req.query.edit ? String(req.query.edit) : null;
    const record = editId ? await model.findById(editId).lean() : null;

    return res.render('app', {
      appName: APP_NAME,
      page,
      cfg,
      rows,
      record,
      meta: { total, totalPages, currentPage, perPage },
      stats: {},
      charts: {},
      relations,
      recentActivities: [],
      latestClients: [],
      error: null,
      flash: req.session.flash || null,
      currentUser: req.session.user,
      canCreate, canRead, canUpdate, canDelete, canExport, canPrint,
      search, sort, dir, status,
      pageTitle: cfg.title
    });
  } catch (error) {
    console.error(error);
    return res.status(500).render('app', {
      appName: APP_NAME,
      page: 'dashboard',
      cfg: pageConfigs.dashboard,
      rows: [],
      record: null,
      meta: {},
      stats: {},
      charts: {},
      relations: {},
      recentActivities: [],
      latestClients: [],
      error: 'An unexpected error occurred while loading the page.',
      flash: null,
      currentUser: req.session.user,
      canCreate: false,
      canRead: false,
      canUpdate: false,
      canDelete: false,
      canExport: false,
      canPrint: false
    });
  }
});

app.post('/app/:page/:action', ensureAuthenticated, async (req, res) => {
  try {
    const page = String(req.params.page || '').toLowerCase();
    const action = String(req.params.action || '').toLowerCase();
    const cfg = pageConfigs[page];

    if (!cfg || !cfg.modelKey) return res.redirect('/app?page=dashboard');
    const modelInfo = MODELS[cfg.modelKey];
    const Model = modelInfo.model;

    const recordId = sanitizeInput(req.body.id || req.body._id || '');
    const user = req.session.user;

    const recordData = {};
    for (const key of Object.keys(req.body)) {
      if (['_id', 'id', '__v'].includes(key)) continue;
      recordData[key] = sanitizeInput(req.body[key]);
    }

    if (action === 'create') {
      if (!hasPermission(user, 'create')) throw new Error('Access denied.');

      if (page === 'users') {
        if (!recordData.password) throw new Error('Password is required for user creation.');
        recordData.passwordHash = hashPassword(recordData.password);
        delete recordData.password;
      }

      if (page === 'clients' && !recordData.clientCode) recordData.clientCode = generateCode('CLT');
      if (page === 'projects' && !recordData.projectCode) recordData.projectCode = generateCode('PRJ');
      if (page === 'tasks' && !recordData.taskCode) recordData.taskCode = generateCode('TSK');
      if (page === 'documents' && !recordData.documentCode) recordData.documentCode = generateCode('DOC');
      if (page === 'invoices' && !recordData.invoiceNumber) recordData.invoiceNumber = generateCode('INV');
      if (page === 'payments' && !recordData.paymentNumber) recordData.paymentNumber = generateCode('PAY');
      if (page === 'reports' && !recordData.reportCode) recordData.reportCode = generateCode('RPT');
      if (page === 'modules' && !recordData.moduleKey) recordData.moduleKey = generateCode('MOD');
      if (page === 'notifications' && !recordData.title) recordData.title = 'Notification';
      if (page === 'settings' && !recordData.key) recordData.key = generateCode('SET');

      recordData.createdBy = user._id;
      recordData.status = recordData.status || 'Active';

      const created = await Model.create(recordData);
      await logAudit({ user, action: 'Insert', entityName: modelInfo.entity, entityId: created._id, summary: `Created ${modelInfo.entity}` }, req);
      req.session.flash = { type: 'success', message: `${cfg.title} created successfully.` };
      return res.redirect(`/app?page=${page}`);
    }

    if (action === 'update') {
      if (!hasPermission(user, 'update')) throw new Error('Access denied.');
      if (!recordId) throw new Error('Missing record ID.');

      if (page === 'users' && recordData.password) {
        recordData.passwordHash = hashPassword(recordData.password);
        delete recordData.password;
      }

      delete recordData.createdAt;
      delete recordData.updatedAt;
      delete recordData.createdBy;

      const updated = await Model.findByIdAndUpdate(recordId, { $set: recordData }, { new: true, runValidators: true });
      if (!updated) throw new Error('Record not found.');
      await logAudit({ user, action: 'Update', entityName: modelInfo.entity, entityId: updated._id, summary: `Updated ${modelInfo.entity}` }, req);
      req.session.flash = { type: 'success', message: `${cfg.title} updated successfully.` };
      return res.redirect(`/app?page=${page}`);
    }

    if (action === 'delete') {
      if (!hasPermission(user, 'delete')) throw new Error('Access denied.');
      if (!recordId) throw new Error('Missing record ID.');
      const deleted = await Model.findByIdAndDelete(recordId);
      if (!deleted) throw new Error('Record not found.');
      await logAudit({ user, action: 'Delete', entityName: modelInfo.entity, entityId: recordId, summary: `Deleted ${modelInfo.entity}` }, req);
      req.session.flash = { type: 'success', message: `${cfg.title} deleted successfully.` };
      return res.redirect(`/app?page=${page}`);
    }

    if (action === 'print') {
      if (!hasPermission(user, 'print')) throw new Error('Access denied.');
      await logAudit({ user, action: 'Print', entityName: modelInfo.entity, entityId: recordId || '', summary: `Printed ${modelInfo.entity}` }, req);
      req.session.flash = { type: 'info', message: `${cfg.title} print requested.` };
      return res.redirect(`/app?page=${page}`);
    }

    if (action === 'export') {
      if (!hasPermission(user, 'export')) throw new Error('Access denied.');
      await logAudit({ user, action: 'Export', entityName: modelInfo.entity, entityId: recordId || '', summary: `Exported ${modelInfo.entity}` }, req);
      req.session.flash = { type: 'info', message: `${cfg.title} export requested.` };
      return res.redirect(`/app?page=${page}`);
    }

    if (action === 'settings') {
      await logAudit({ user, action: 'Settings', entityName: 'Setting', entityId: recordId || '', summary: 'Updated settings' }, req);
      req.session.flash = { type: 'success', message: 'Settings updated.' };
      return res.redirect(`/app?page=settings`);
    }

    throw new Error('Invalid action.');
  } catch (error) {
    console.error(error);
    req.session.flash = { type: 'danger', message: error.message || 'Operation failed.' };
    const redirectPage = req.params.page ? String(req.params.page).toLowerCase() : 'dashboard';
    return res.redirect(`/app?page=${redirectPage}`);
  }
});

app.post('/change-password', ensureAuthenticated, async (req, res) => {
  try {
    const currentPassword = sanitizeInput(req.body.currentPassword);
    const newPassword = sanitizeInput(req.body.newPassword);
    const confirmPassword = sanitizeInput(req.body.confirmPassword);

    if (!newPassword || newPassword.length < 8) throw new Error('New password must be at least 8 characters.');
    if (newPassword !== confirmPassword) throw new Error('Passwords do not match.');

    const user = await User.findById(req.session.userId);
    if (!user) throw new Error('User not found.');
    if (user.passwordHash !== hashPassword(currentPassword)) throw new Error('Current password is incorrect.');

    user.passwordHash = hashPassword(newPassword);
    user.forcePasswordChange = false;
    await user.save();

    await logAudit({ user: req.session.user, action: 'Update', entityName: 'User', entityId: user._id, summary: 'Password changed' }, req);
    req.session.flash = { type: 'success', message: 'Password changed successfully.' };
    return res.redirect('/app?page=settings');
  } catch (error) {
    console.error(error);
    req.session.flash = { type: 'danger', message: error.message || 'Password change failed.' };
    return res.redirect('/app?page=settings');
  }
});

