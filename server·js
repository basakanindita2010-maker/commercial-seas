    ['invoices', 'Invoices', 'fa-file-invoice-dollar', '/app?page=invoices'],
    ['payments', 'Payments', 'fa-credit-card', '/app?page=payments'],
    ['notifications', 'Notifications', 'fa-bell', '/app?page=notifications'],
    ['reports', 'Reports', 'fa-chart-line', '/app?page=reports'],
    ['auditlogs', 'Audit Logs', 'fa-shield-halved', '/app?page=auditlogs'],
    ['settings', 'Settings', 'fa-gear', '/app?page=settings']
  ];

  for (let i = 0; i < modules.length; i++) {
    const [moduleKey, moduleName, icon, route] = modules[i];
    const exists = await Module.findOne({ moduleKey }).lean();
    if (!exists) {
      await Module.create({ moduleKey, moduleName, icon, route, order: i + 1, status: 'Active', createdBy: null });
    }
  }
}

