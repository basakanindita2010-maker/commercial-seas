const rolePermissions = {
  Administrator: { all: true },
  Manager: { all: false, create: true, read: true, update: true, delete: false, export: true, print: true },
  Staff: { all: false, create: true, read: true, update: true, delete: false, export: false, print: false },
  Operator: { all: false, create: true, read: true, update: false, delete: false, export: false, print: false },
  Viewer: { all: false, create: false, read: true, update: false, delete: false, export: true, print: true }
};

function escapeHtml(str) {
  return String(str ?? '').replace(/[&<>"']/g, (m) => ({
    '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
  }[m]));
}

function sanitizeInput(value) {
  if (typeof value === 'string') return value.trim().replace(/\$/g, '').replace(/\u0000/g, '');
  return value;
}

function hashPassword(password) {
  return crypto.createHash('sha256').update(String(password)).digest('hex');
}

function generateCode(prefix) {
  return `${prefix}-${Date.now().toString(36).toUpperCase()}-${crypto.randomBytes(2).toString('hex').toUpperCase()}`;
}

function roleLabel(role) {
  return role || 'Viewer';
}

function hasPermission(user, action) {
  if (!user) return false;
  const perms = rolePermissions[user.role] || rolePermissions.Viewer;
  if (perms.all) return true;
  return Boolean(perms[action]);
}

async function logAudit({ user, action, entityName, entityId = '', summary = '' }, req = null) {
  try {
    await AuditLog.create({
      action,
      entityName,
      entityId: String(entityId || ''),
      summary: String(summary || ''),
      ipAddress: req ? (req.headers['x-forwarded-for'] || req.socket.remoteAddress || '') : '',
      userAgent: req ? (req.headers['user-agent'] || '') : '',
      createdBy: user ? user._id : null,
      status: 'Active'
    });
  } catch (e) {
    console.error('Audit log write failed:', e.message);
  }
}

function ensureAuthenticated(req, res, next) {
  if (!req.session.userId) return res.redirect('/login');
  return next();
}

function normalizeBoolean(val) {
  return ['true', '1', 'on', 'yes'].includes(String(val).toLowerCase());
}

