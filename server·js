app.post('/login', async (req, res) => {
  try {
    const email = sanitizeInput(req.body.email).toLowerCase();
    const password = sanitizeInput(req.body.password);
    const remember = normalizeBoolean(req.body.remember);

    const user = await User.findOne({ email, status: 'Active' }).lean();
    if (!user || user.passwordHash !== hashPassword(password)) {
      return res.status(401).render('login', { appName: APP_NAME, error: 'Invalid email or password.' });
    }

    req.session.regenerate(async (err) => {
      if (err) {
        console.error(err);
        return res.status(500).render('login', { appName: APP_NAME, error: 'Unable to start session.' });
      }

      req.session.userId = String(user._id);
      req.session.user = {
        _id: String(user._id),
        fullName: user.fullName,
        email: user.email,
        role: user.role
      };

      if (remember) {
        req.session.cookie.maxAge = 1000 * 60 * 60 * 24 * 30;
      }

      await User.updateOne({ _id: user._id }, { $set: { lastLoginAt: new Date() }, $inc: { loginCount: 1 } });
      await logAudit({ user, action: 'Login', entityName: 'User', entityId: user._id, summary: `User logged in: ${user.email}` }, req);
      return res.redirect('/app?page=dashboard');
    });
  } catch (error) {
    console.error(error);
    return res.status(500).render('login', { appName: APP_NAME, error: 'Login failed due to a server error.' });
  }
});

